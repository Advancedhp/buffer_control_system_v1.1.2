from __future__ import annotations

from copy import deepcopy

import pandas as pd
import streamlit as st

from src.buffer_model import calculate_dataset
from src.charts import buffer_comparison, ibuf_bar, pshort_bar, scenario_delta_chart, status_pie
from src.data_loader import create_flat_template_bytes, load_excel_workbook
from src.demo_data import get_demo_dataframe, empty_input_dataframe
from src.diagrams import architecture_diagram, process_diagram
from src.export import multi_sheet_export_bytes
from src.recommendations import add_recommendations
from src.schema import REQUIRED_COLUMNS, CRITICALITY_CLASSES, COEFF_MODES
from src.validation import limit_errors, normalize_dataframe, validate_dataframe

st.set_page_config(
    page_title="Контроль буферных запасов ROP",
    page_icon="📦",
    layout="wide",
    initial_sidebar_state="expanded",
)

APP_TITLE = "Модуль оценки и непрерывного контроля буферных запасов для ROP"


def show_toast(message: str, icon: str = "ℹ️") -> None:
    if hasattr(st, "toast"):
        st.toast(message, icon=icon)


def show_validation_errors(errors: list[str]) -> None:
    limited = limit_errors(errors)
    if hasattr(st, "dialog"):
        @st.dialog("Ошибка валидации данных")
        def _dialog():
            st.write("Исправьте ошибки и повторите расчёт:")
            for err in limited:
                st.error(err)
        _dialog()
    else:
        st.error("Ошибка валидации данных")
        for err in limited:
            st.write(f"- {err}")


def init_state() -> None:
    if "scenario_name" not in st.session_state:
        st.session_state.scenario_name = "Стабильный режим"
    if "input_df" not in st.session_state:
        st.session_state.input_df = get_demo_dataframe(st.session_state.scenario_name)
    if "calculated_df" not in st.session_state:
        st.session_state.calculated_df = calculate_current(st.session_state.input_df, silent=True)
    if "last_before_scenario" not in st.session_state:
        st.session_state.last_before_scenario = None
    if "last_after_scenario" not in st.session_state:
        st.session_state.last_after_scenario = None


def calculate_current(df: pd.DataFrame, silent: bool = False) -> pd.DataFrame:
    normalized = normalize_dataframe(df)
    errors = validate_dataframe(normalized)
    if errors:
        if not silent:
            show_validation_errors(errors)
        return pd.DataFrame()
    calculated = calculate_dataset(normalized)
    calculated = add_recommendations(calculated)
    return calculated


def sidebar_controls() -> None:
    st.sidebar.title("⚙️ Управление")
    st.sidebar.caption("Выберите источник данных и режим работы.")

    source = st.sidebar.radio(
        "Источник данных",
        ["Встроенные демо-данные", "Ручной ввод", "Загрузка Excel"],
        index=0,
    )

    if source == "Встроенные демо-данные":
        scenario = st.sidebar.selectbox(
            "Демо-сценарий",
            ["Стабильный режим", "Средний режим", "Кризисный режим"],
            index=["Стабильный режим", "Средний режим", "Кризисный режим"].index(st.session_state.scenario_name),
        )
        if st.sidebar.button("Загрузить демо-сценарий", use_container_width=True):
            st.session_state.scenario_name = scenario
            st.session_state.input_df = get_demo_dataframe(scenario)
            st.session_state.calculated_df = calculate_current(st.session_state.input_df)
            show_toast("Демо-сценарий загружен", "✅")
        if st.sidebar.button("Сбросить к исходному демо", use_container_width=True):
            st.session_state.input_df = get_demo_dataframe(st.session_state.scenario_name)
            st.session_state.calculated_df = calculate_current(st.session_state.input_df)
            show_toast("Данные восстановлены", "🔄")

    elif source == "Ручной ввод":
        rows = st.sidebar.number_input("Количество строк", min_value=1, max_value=100, value=5, step=1)
        if st.sidebar.button("Создать пустую таблицу", use_container_width=True):
            st.session_state.input_df = empty_input_dataframe(int(rows))
            st.session_state.calculated_df = calculate_current(st.session_state.input_df)
            show_toast("Пустая таблица создана", "✅")

    else:
        uploaded = st.sidebar.file_uploader("Загрузите Excel-файл", type=["xlsx", "xls"])
        if uploaded is not None:
            try:
                st.session_state.input_df = load_excel_workbook(uploaded)
                st.session_state.calculated_df = calculate_current(st.session_state.input_df)
                show_toast("Excel-файл загружен", "✅")
            except Exception as exc:
                st.sidebar.error(f"Не удалось загрузить файл: {exc}")
        template_bytes = create_flat_template_bytes(rows=5)
        st.sidebar.download_button(
            "Скачать шаблон Excel",
            data=template_bytes,
            file_name="buffer_input_template.xlsx",
            mime="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            use_container_width=True,
        )

    st.sidebar.divider()
    if st.sidebar.button("Пересчитать текущие данные", use_container_width=True):
        st.session_state.calculated_df = calculate_current(st.session_state.input_df)
        if not st.session_state.calculated_df.empty:
            show_toast("Расчёт выполнен", "✅")


def dashboard_tab(df: pd.DataFrame) -> None:
    st.subheader("Главная панель")
    if df.empty:
        st.warning("Нет рассчитанных данных.")
        return

    total = len(df)
    critical = int((df["status"] == "Критическое отклонение").sum())
    warning = int((df["status"] == "Предупреждение").sum())
    normal = int((df["status"] == "Норма").sum())
    surplus = int((df["status"] == "Избыточный буфер").sum())
    avg_ibuf = df["Ibuf"].replace([float("inf"), -float("inf")], pd.NA).dropna().mean()

    c1, c2, c3, c4, c5 = st.columns(5)
    c1.metric("Всего позиций", total)
    c2.metric("Критические", critical)
    c3.metric("Предупреждения", warning)
    c4.metric("Норма", normal)
    c5.metric("Избыточные", surplus)
    st.metric("Средний индекс обеспеченности Ibuf", f"{avg_ibuf:.2f}" if pd.notna(avg_ibuf) else "н/д")

    left, right = st.columns([1, 1])
    with left:
        st.plotly_chart(status_pie(df), use_container_width=True)
    with right:
        st.plotly_chart(pshort_bar(df), use_container_width=True)

    st.plotly_chart(ibuf_bar(df), use_container_width=True)

    st.markdown("#### Наиболее проблемные позиции")
    cols = ["item_id", "item_name", "rop_name", "A", "Bopt", "Pshort_current", "Ibuf", "status"]
    st.dataframe(df.sort_values(["Ibuf", "Pshort_current"], ascending=[True, False])[cols].head(10), use_container_width=True, hide_index=True)


def data_tab() -> None:
    st.subheader("Данные")
    st.caption("Редактируется рабочая копия данных. Встроенные демо-сценарии остаются неизменными.")

    df = st.session_state.input_df.copy()
    edited = st.data_editor(
        df,
        use_container_width=True,
        num_rows="dynamic",
        hide_index=True,
        column_config={
            "criticality_class": st.column_config.SelectboxColumn("criticality_class", options=CRITICALITY_CLASSES),
            "coeff_mode": st.column_config.SelectboxColumn("coeff_mode", options=COEFF_MODES),
        },
        key="data_editor",
    )

    col1, col2 = st.columns([1, 1])
    with col1:
        if st.button("Применить изменения", use_container_width=True):
            normalized = normalize_dataframe(edited)
            errors = validate_dataframe(normalized)
            if errors:
                show_validation_errors(errors)
            else:
                st.session_state.input_df = normalized
                st.session_state.calculated_df = calculate_current(normalized)
                show_toast("Изменения применены", "✅")
                st.rerun()
    with col2:
        if st.button("Отменить несохранённые изменения", use_container_width=True):
            st.rerun()

    st.markdown("#### Обязательные поля")
    st.code(", ".join(REQUIRED_COLUMNS), language="text")


def calculation_tab(df: pd.DataFrame) -> None:
    st.subheader("Расчёт буфера")
    if df.empty:
        st.warning("Нет рассчитанных данных.")
        return
    display_cols = [
        "item_id", "item_name", "rop_name", "criticality_class", "O", "P", "R", "D_avg", "sigma_D", "L_avg", "sigma_L",
        "A", "sigma_LT", "z", "Kcrit", "Kload", "Kdev", "Bstat", "Btar", "Pshort", "Pshort_current", "holding_cost", "expected_stop_loss",
        "expected_total_cost", "Bopt", "reorder_point", "Ibuf", "status", "optimization_note",
    ]
    available_cols = [col for col in display_cols if col in df.columns]
    rounded = df[available_cols].copy()
    numeric_cols = rounded.select_dtypes(include="number").columns
    rounded[numeric_cols] = rounded[numeric_cols].round(4)
    st.dataframe(rounded, use_container_width=True, hide_index=True)
    st.plotly_chart(buffer_comparison(df), use_container_width=True)


def monitoring_tab(df: pd.DataFrame) -> None:
    st.subheader("Мониторинг ROP")
    if df.empty:
        st.warning("Нет рассчитанных данных.")
        return
    rop_options = ["Все"] + sorted(df["rop_name"].dropna().unique().tolist())
    selected_rop = st.selectbox("Ограничивающий ресурс", rop_options)
    view = df if selected_rop == "Все" else df[df["rop_name"] == selected_rop]
    st.plotly_chart(ibuf_bar(view), use_container_width=True)
    st.plotly_chart(buffer_comparison(view), use_container_width=True)
    st.dataframe(view[["item_id", "item_name", "rop_name", "A", "Btar", "Bopt", "reorder_point", "Ibuf", "status"]].round(3), use_container_width=True, hide_index=True)


def scenario_tab() -> None:
    st.subheader("Сценарный анализ")
    base_df = st.session_state.input_df.copy()
    if base_df.empty:
        st.warning("Нет исходных данных.")
        return

    st.caption("Сценарный анализ работает на копии текущих данных и не портит исходную рабочую таблицу.")
    col1, col2, col3 = st.columns(3)
    demand_factor = col1.slider("Изменение среднего спроса D_avg, %", -50, 100, 0, 5)
    sigma_d_factor = col2.slider("Изменение вариативности спроса sigma_D, %", -50, 150, 0, 5)
    lead_factor = col3.slider("Изменение срока поставки L_avg, %", -30, 100, 0, 5)
    col4, col5, col6 = st.columns(3)
    sigma_l_factor = col4.slider("Изменение вариативности поставки sigma_L, %", -30, 150, 0, 5)
    stock_factor = col5.slider("Изменение остатков O, %", -80, 100, 0, 5)
    cstop_factor = col6.slider("Изменение стоимости простоя Cstop, %", -50, 200, 0, 5)
    col7, col8, col9 = st.columns(3)
    rop_load_delta = col7.slider("Добавить к загрузке ROP", -0.30, 0.50, 0.00, 0.01)
    p_diag_delta = col8.slider("Добавить к p_diag", -0.20, 0.40, 0.00, 0.01)
    p_rep_delta = col9.slider("Добавить к p_rep", -0.20, 0.40, 0.00, 0.01)

    if st.button("Применить сценарий", use_container_width=True):
        before = calculate_current(base_df, silent=True)
        scenario_df = base_df.copy()
        scenario_df["D_avg"] = scenario_df["D_avg"] * (1 + demand_factor / 100)
        scenario_df["sigma_D"] = scenario_df["sigma_D"] * (1 + sigma_d_factor / 100)
        scenario_df["L_avg"] = scenario_df["L_avg"] * (1 + lead_factor / 100)
        scenario_df["sigma_L"] = scenario_df["sigma_L"] * (1 + sigma_l_factor / 100)
        scenario_df["O"] = scenario_df["O"] * (1 + stock_factor / 100)
        scenario_df["Cstop"] = scenario_df["Cstop"] * (1 + cstop_factor / 100)
        scenario_df["rop_load"] = (scenario_df["rop_load"] + rop_load_delta).clip(0, 1.5)
        scenario_df["p_diag"] = (scenario_df["p_diag"] + p_diag_delta).clip(0, 1)
        scenario_df["p_rep"] = (scenario_df["p_rep"] + p_rep_delta).clip(0, 1)
        after = calculate_current(scenario_df, silent=True)
        st.session_state.last_before_scenario = before
        st.session_state.last_after_scenario = after
        show_toast("Сценарий рассчитан", "✅")

    before = st.session_state.last_before_scenario
    after = st.session_state.last_after_scenario
    if before is not None and after is not None and not after.empty:
        st.plotly_chart(scenario_delta_chart(before, after), use_container_width=True)
        merged = before[["item_id", "item_name", "Bopt", "Ibuf", "status"]].merge(
            after[["item_id", "Bopt", "Ibuf", "status"]], on="item_id", suffixes=("_до", "_после")
        )
        st.dataframe(merged.round(3), use_container_width=True, hide_index=True)


def diagrams_tab(df: pd.DataFrame) -> None:
    st.subheader("Схемы")
    st.plotly_chart(architecture_diagram(), use_container_width=True)
    if df.empty:
        st.warning("Для процессной схемы нужны рассчитанные данные.")
        return
    item_options = (df["item_id"] + " — " + df["item_name"]).tolist()
    selected = st.selectbox("Позиция для процессной схемы", item_options)
    item_id = selected.split(" — ")[0]
    row = df[df["item_id"] == item_id].iloc[0].to_dict()
    st.plotly_chart(process_diagram(row), use_container_width=True)


def recommendations_tab(df: pd.DataFrame) -> None:
    st.subheader("Управленческое заключение")
    if df.empty:
        st.warning("Нет рассчитанных данных.")
        return
    status_filter = st.multiselect(
        "Фильтр по статусам",
        ["Критическое отклонение", "Предупреждение", "Норма", "Избыточный буфер"],
        default=["Критическое отклонение", "Предупреждение", "Избыточный буфер"],
    )
    view = df[df["status"].isin(status_filter)] if status_filter else df
    for _, row in view.sort_values(["status", "Ibuf"]).iterrows():
        with st.expander(f"{row['item_id']} — {row['item_name']} | {row['status']}", expanded=row["status"] in ["Критическое отклонение", "Предупреждение"]):
            st.write(row["recommendation"])
            st.caption(row.get("optimization_note", ""))


def testing_tab() -> None:
    st.subheader("Тестирование модели")
    st.caption("Быстрые тесты проверяют направленность реакции алгоритма.")

    tests = {
        "Рост спроса": {"D_avg": 1.30, "sigma_D": 1.30},
        "Рост срока поставки": {"L_avg": 1.30, "sigma_L": 1.30},
        "Ухудшение оборудования": {"p_diag_add": 0.20, "p_rep_add": 0.15},
        "Снижение остатков": {"O": 0.50},
        "Рост стоимости простоя": {"Cstop": 2.00},
        "Рост стоимости хранения": {"h": 2.00},
    }
    selected_test = st.selectbox("Выберите тест", list(tests.keys()))
    if st.button("Запустить тест", use_container_width=True):
        base = st.session_state.input_df.copy()
        before = calculate_current(base, silent=True)
        test_df = base.copy()
        changes = tests[selected_test]
        for col, factor in changes.items():
            if col.endswith("_add"):
                real_col = col.replace("_add", "")
                test_df[real_col] = (test_df[real_col] + factor).clip(0, 1)
            else:
                test_df[col] = test_df[col] * factor
        after = calculate_current(test_df, silent=True)
        if before.empty or after.empty:
            st.error("Тест не выполнен из-за ошибок в исходных данных.")
            return
        before_mean_b = before["Bopt"].mean()
        after_mean_b = after["Bopt"].mean()
        before_mean_i = before["Ibuf"].replace([float("inf"), -float("inf")], pd.NA).dropna().mean()
        after_mean_i = after["Ibuf"].replace([float("inf"), -float("inf")], pd.NA).dropna().mean()
        c1, c2, c3, c4 = st.columns(4)
        c1.metric("Средний Bopt до", f"{before_mean_b:.2f}")
        c2.metric("Средний Bopt после", f"{after_mean_b:.2f}", delta=f"{after_mean_b-before_mean_b:.2f}")
        c3.metric("Средний Ibuf до", f"{before_mean_i:.2f}")
        c4.metric("Средний Ibuf после", f"{after_mean_i:.2f}", delta=f"{after_mean_i-before_mean_i:.2f}")
        st.plotly_chart(scenario_delta_chart(before, after), use_container_width=True)
        st.dataframe(
            before[["item_id", "Bopt", "Ibuf", "status"]].merge(after[["item_id", "Bopt", "Ibuf", "status"]], on="item_id", suffixes=("_до", "_после")).round(3),
            use_container_width=True,
            hide_index=True,
        )


def documentation_tab() -> None:
    st.subheader("Документация модели")
    st.markdown(
        """
### Назначение модуля
Модуль предназначен для оценки и непрерывного контроля буферных запасов для ресурса, ограничивающего производство (ROP). Он рассчитывает оптимальный буфер, точку заказа, вероятность дефицита и статус позиции.

### Основные входные переменные
- `O` — фактический остаток позиции.
- `P` — ожидаемые поступления по размещённым заказам.
- `R` — подтверждённая потребность производства.
- `D_avg` — средний спрос или средняя интенсивность расхода.
- `sigma_D` — стандартное отклонение спроса.
- `L_avg` — средний срок пополнения.
- `sigma_L` — стандартное отклонение срока поставки.
- `p_diag` — вероятность нахождения оборудования в состоянии диагностики.
- `p_rep` — вероятность аварийного ремонта.
- `h` — удельные издержки хранения единицы запаса.
- `Cstop` — стоимость простоя ROP при отсутствии позиции.

### Формулы
`A = O + P - R`

`σLT = sqrt(L_avg * sigma_D² + D_avg² * sigma_L²)`

`z = z0 * (1 + alpha * p_diag + beta * p_rep)`

`Bstat = z * σLT`

`Btar = Bstat * Kcrit * Kload * Kdev`

`Pshort(B,t) = 1 - Ф(B / σLT)`

`Pshort_current = 1, если A <= 0; иначе 1 - Ф(A / σLT)`

`Bopt = argmin { h * B + Cstop * Pshort(B,t) }, B >= Btar`

`s = D_avg * L_avg + Bopt`

`Ibuf = A / Bopt`

### Статусы
- `Ibuf <= 0.70` — критическое отклонение.
- `0.70 < Ibuf <= 1.00` — предупреждение.
- `1.00 < Ibuf <= 1.50` — норма.
- `Ibuf > 1.50` — избыточный буфер.

### Ограничения модели
В версии 1.0 используется нормальная аппроксимация вероятности дефицита. Для внедрения на предприятии параметры `h`, `Cstop`, `z0`, `alpha`, `beta` и шкалы коэффициентов должны быть откалиброваны на фактических данных.
"""
    )


def export_tab(df: pd.DataFrame) -> None:
    st.subheader("Экспорт")
    if df.empty:
        st.warning("Нет рассчитанных данных для экспорта.")
        return
    excel_bytes = multi_sheet_export_bytes(st.session_state.input_df, df)
    st.download_button(
        "Скачать результаты расчёта в Excel",
        data=excel_bytes,
        file_name="buffer_calculation_result.xlsx",
        mime="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
        use_container_width=True,
    )
    st.info("Файл содержит два листа: исходные данные и результаты расчёта.")


def main() -> None:
    init_state()
    sidebar_controls()
    st.title(APP_TITLE)
    st.caption("Локальный демонстрационный модуль для научной работы. Встроенные демо-сценарии являются неизменяемыми; редактируется только рабочая копия данных.")

    calculated_df = st.session_state.calculated_df

    tabs = st.tabs([
        "Главная панель",
        "Данные",
        "Расчёт буфера",
        "Мониторинг ROP",
        "Сценарный анализ",
        "Схемы",
        "Управленческое заключение",
        "Тестирование модели",
        "Документация",
        "Экспорт",
    ])

    with tabs[0]:
        dashboard_tab(calculated_df)
    with tabs[1]:
        data_tab()
    with tabs[2]:
        calculation_tab(calculated_df)
    with tabs[3]:
        monitoring_tab(calculated_df)
    with tabs[4]:
        scenario_tab()
    with tabs[5]:
        diagrams_tab(calculated_df)
    with tabs[6]:
        recommendations_tab(calculated_df)
    with tabs[7]:
        testing_tab()
    with tabs[8]:
        documentation_tab()
    with tabs[9]:
        export_tab(calculated_df)


if __name__ == "__main__":
    main()
